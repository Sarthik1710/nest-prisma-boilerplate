model user {
    id                  String                  @id @default(cuid())
    firstName           String
    lastName            String
    email               String
    userType            userType
    password            String

    isActive            Boolean                 @default(true)
    isDeleted           Boolean                 @default(false)
    createdAt           DateTime                @default(now())
    updatedAt           DateTime                @updatedAt
    deletedAt           DateTime?
    createdBy           String
    updatedBy           String
    deletedBy           String?
}
